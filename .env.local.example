# Copy to .env.local and fill in values. For local dev, use localhost domain vars (see comments below).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Signup email verification (requires RESEND_API_KEY + verified domain)
ENABLE_OTP=true
NEXT_PUBLIC_ENABLE_OTP=true

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@juwa2.com

# Cloudflare Turnstile (signup + password reset)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Production (Vercel) ---
NEXT_PUBLIC_ROOT_DOMAIN=partners.juwa2.com
NEXT_PUBLIC_SUPPORT_DOMAIN=juwa2.com
NEXT_PUBLIC_APP_URL=https://juwa2.com
PUBLIC_SITE_URL=https://juwa2.com

# --- Local dev (.env.local) use instead of production lines above ---
# NEXT_PUBLIC_ROOT_DOMAIN=localhost
# NEXT_PUBLIC_SUPPORT_DOMAIN=localhost
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_PRIMARY_SUPPORT_BUSINESS_SLUG=juwa2

# Optional: synthetic email domain for dashboard-created support staff
# STAFF_AUTH_EMAIL_DOMAIN=staff.juwa2.com

# Admin account: create in Supabase Dashboard (Auth → Users), then run SQL — see supabase/00_START_HERE.sql
