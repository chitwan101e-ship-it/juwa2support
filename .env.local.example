NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_OTP=false
NEXT_PUBLIC_ENABLE_OTP=false

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@juwa2support.com
# OTP and Cloudflare Turnstile disabled for signup (see signup page + auth routes)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Platform domain — business partner subdomains only (slug.ROOT_DOMAIN)
NEXT_PUBLIC_ROOT_DOMAIN=partners.juwa2support.com

# Juwa2 player support portal (login, feed, signup) — separate from partner subdomains
NEXT_PUBLIC_SUPPORT_DOMAIN=juwa2support.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production links in emails: PUBLIC_SITE_URL=https://juwa2support.com

# Which business receives player support chat from the feed (must match public.businesses.slug)
NEXT_PUBLIC_PRIMARY_SUPPORT_BUSINESS_SLUG=juwa2

# Optional: synthetic email domain for dashboard-created support staff
# STAFF_AUTH_EMAIL_DOMAIN=staff.juwa2support.com

# Admin account: create in Supabase Dashboard (Auth → Users), then run SQL — see supabase/00_START_HERE.sql
